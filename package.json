{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.js",
  "homepage": "./",
  "build": {
    "appId": "com.mydesckpro.app",
    "productName": "MyDesck PRO",
    "directories": {
      "output": "C:\\_mydesck_build"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.js",
      "preload.cjs",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "dir",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development node node_modules/electron/cli.js .\"",
    "electron:start": "cross-env NODE_ENV=production node node_modules/electron/cli.js .",
    "electron:build-start": "npm run build && cross-env NODE_ENV=production node node_modules/electron/cli.js .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --win dir",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@fontsource/ibm-plex-sans-arabic": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/rubik": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-persist-client": "^5.90.12",
    "@types/jszip": "^3.4.0",
    "@types/qrcode": "^1.5.6",
    "arabic-reshaper": "^1.1.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.1",
    "react-i18next": "^16.3.5",
    "recharts": "^3.5.1",
    "rtl-detect": "^1.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "electron": "^39.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.1.0",
    "wait-on": "^9.0.3"
  }
}

{
  "headers": [
    {
      "source": "/(sw.js|registerSW.js|version.json|release-notes.json|manifest.webmanifest)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!version\\.json|release-notes\\.json|sw\\.js|registerSW\\.js|manifest\\.webmanifest|favicon\\.ico|robots\\.txt|sitemap\\.xml|assets/|locales/|google.*\\.html).*)",
      "destination": "/index.html"
    }
  ]
}

{
  "headers": [
    {
      "source": "/(sw.js|registerSW.js|version.json|release-notes.json)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|locales/|.*\\.xml|.*\\.txt|.*\\.ico|.*\\.png|.*\\.json|google.*\\.html|sw\\.js|registerSW\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
